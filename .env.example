# Bambu Lab Printer - LAN credentials.
# You don't need to fill this in by hand — the easier path is to register the
# server with Claude Desktop without any env vars and let the `setup_printer`
# tool write this file for you. See README "Setup" section.
#
# Where to find each value on the printer touchscreen:
#   Settings -> WLAN     -> tap (i) next to the connected network        => IP
#   Settings -> Device   -> Device Info -> Serial Number                 => SERIAL
#   Settings -> WLAN     -> LAN Mode Liveview (must be ON, 8 chars)      => ACCESS_CODE

BAMBU_IP=192.168.1.100
BAMBU_SERIAL=01P00AXXXXXXXXX
BAMBU_ACCESS_CODE=XXXXXXXX

# Optional: where to store the maintenance ledger.
# Defaults to <project-root>/maintenance.json (next to dist/).
# MAINTENANCE_LEDGER_PATH=/absolute/path/to/maintenance.json
